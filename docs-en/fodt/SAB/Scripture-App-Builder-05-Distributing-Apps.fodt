     <table:table-cell table:style-name="Table4.B1" office:value-type="string">
      <text:p text:style-name="P11" loext:marker-style-name="T32"><text:span text:style-name="T32">Email</text:span><text:span text:style-name="T32"/></text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table4.B1" office:value-type="string">
      <text:p text:style-name="P11" loext:marker-style-name="T7"><text:span text:style-name="T7">Email the APK directly to one or more people. Save the attachment to their phone and tap to install the app.</text:span><text:span text:style-name="T7"/></text:p>
     </table:table-cell>
