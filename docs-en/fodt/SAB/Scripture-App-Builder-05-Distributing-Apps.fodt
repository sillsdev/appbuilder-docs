     <table:table-cell table:style-name="Table4.B1" office:value-type="string">
      <text:p text:style-name="P11" loext:marker-style-name="T32"><text:span text:style-name="T32">Web Sites</text:span><text:span text:style-name="T32"/></text:p>
     </table:table-cell>
     <table:table-cell table:style-name="Table4.B1" office:value-type="string">
      <text:p text:style-name="P11" loext:marker-style-name="T7"><text:span text:style-name="T7">Post the app installation file (APK) on your website for people to find and download. Once people have downloaded the file, they tap on it to install it.</text:span><text:span text:style-name="T7"/></text:p>
     </table:table-cell>
    </table:table-row>
