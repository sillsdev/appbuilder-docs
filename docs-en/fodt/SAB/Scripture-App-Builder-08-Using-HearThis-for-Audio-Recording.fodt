    </draw:custom-shape><draw:frame draw:style-name="fr2" draw:name="Frame11" text:anchor-type="char" svg:x="0.0008in" svg:y="1.0244in" svg:width="1.75in" svg:height="0.3138in" draw:z-index="26">
     <draw:text-box>
