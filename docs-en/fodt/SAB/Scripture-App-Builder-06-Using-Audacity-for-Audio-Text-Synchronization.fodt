    <text:list-item>
     <text:p text:style-name="P71" loext:marker-style-name="T4"><text:span text:style-name="T4">Change the key binding for this line to Space (rather than Shift+A).</text:span><text:span text:style-name="T4"/></text:p>
    </text:list-item>
   </text:list>
