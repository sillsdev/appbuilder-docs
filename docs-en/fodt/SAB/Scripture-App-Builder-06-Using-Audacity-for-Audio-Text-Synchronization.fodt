     <text:p text:style-name="P96" loext:marker-style-name="T35"><text:span text:style-name="T35">The suggested location in which to install</text:span><text:alphabetical-index-mark text:string-value=" " text:key1="install"/><text:span text:style-name="T35"> Audacity is normally fine, so click </text:span><text:span text:style-name="T36">Next</text:span><text:span text:style-name="T35">.</text:span></text:p>
    </text:list-item>
