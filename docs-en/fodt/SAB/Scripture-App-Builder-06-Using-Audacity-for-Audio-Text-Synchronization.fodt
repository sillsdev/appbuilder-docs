   <text:p text:style-name="P3" loext:marker-style-name="T5"><text:span text:style-name="T5">Scripture App Builder: Using Audacity for </text:span><text:span text:style-name="T5"/></text:p>
   <text:p text:style-name="P3" loext:marker-style-name="T5"><text:span text:style-name="T5">Audio-Text Synchronization</text:span><text:span text:style-name="T5"/></text:p>
