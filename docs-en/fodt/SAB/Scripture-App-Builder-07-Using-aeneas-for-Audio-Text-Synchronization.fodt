   <text:p text:style-name="P77" loext:marker-style-name="T6"><draw:custom-shape text:anchor-type="char" style:rel-height="20%" draw:z-index="12" draw:name="Text Box 2" draw:style-name="gr13" draw:text-style-name="P67" svg:width="2.5524in" svg:height="1.5362in" svg:x="0.0555in" svg:y="0.2201in">
     <text:p text:style-name="Frame_20_contents" loext:marker-style-name="T6"><text:span text:style-name="T6">Change the playback speed here</text:span></text:p>
     <draw:enhanced-geometry draw:mirror-horizontal="false" draw:mirror-vertical="false" draw:glue-points="?f0 0 0 ?f1 ?f0 ?f2 ?f3 ?f1" draw:text-areas="0 0 ?f3 ?f2" svg:viewBox="0 0 0 0" draw:type="ooxml-rect" draw:enhanced-path="M 0 0 L ?f3 0 ?f3 ?f2 0 ?f2 Z N">
      <draw:equation draw:name="f0" draw:formula="logwidth/2"/>
      <draw:equation draw:name="f1" draw:formula="logheight/2"/>
