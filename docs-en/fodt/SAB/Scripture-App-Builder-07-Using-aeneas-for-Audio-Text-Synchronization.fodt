     <svg:desc>C:\Users\Richard\AppData\Local\Microsoft\Windows\INetCache\Content.Word\org1.png</svg:desc>
    </draw:frame><draw:custom-shape text:anchor-type="char" draw:z-index="7" draw:name="Rectangle 10" draw:style-name="gr5" draw:text-style-name="P29" svg:width="0.0496in" svg:height="0.7398in" svg:x="3.3752in" svg:y="0.272in">
     <text:p/>
     <draw:enhanced-geometry draw:mirror-horizontal="false" draw:mirror-vertical="false" draw:glue-points="?f0 0 0 ?f1 ?f0 ?f2 ?f3 ?f1" draw:text-areas="0 0 ?f3 ?f2" svg:viewBox="0 0 0 0" draw:type="ooxml-rect" draw:enhanced-path="M 0 0 L ?f3 0 ?f3 ?f2 0 ?f2 Z N">
