   <text:p text:style-name="P51" loext:marker-style-name="T9"/>
   <text:p text:style-name="P51" loext:marker-style-name="T9"/>
   <text:list text:continue-numbering="true" text:style-name="WWNum28">
    <text:list-item>
     <text:p text:style-name="P49" loext:marker-style-name="T9"><text:span text:style-name="T9">Follow the instructions on each page of the </text:span><text:span text:style-name="T22">Install Android SDK</text:span><text:span text:style-name="T9"> wizard to download each of the Android SDK packages and install them.</text:span></text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="P52" loext:marker-style-name="T9"/>
   <text:p text:style-name="P53" loext:marker-style-name="T9"><text:span text:style-name="T9">When you are asked to specify a target folder, a good place is:</text:span><text:span text:style-name="T9"/></text:p>
   <text:p text:style-name="P53" loext:marker-style-name="T9"><text:span text:style-name="T9"><text:s text:c="8"/></text:span><text:span text:style-name="T26">/Users/</text:span><text:span text:style-name="T28">your-name</text:span><text:span text:style-name="T26">/Android-SDK</text:span><text:span text:style-name="T9">.</text:span></text:p>
   <text:p text:style-name="P54" loext:marker-style-name="T9"/>
   <text:p text:style-name="P55" loext:marker-style-name="T9"><text:span text:style-name="T9">Four packages will be downloaded and installed:</text:span><text:span text:style-name="T9"/></text:p>
   <text:list text:style-name="WWNum41">
    <text:list-item>
     <text:p text:style-name="P56" loext:marker-style-name="T9"><text:span text:style-name="T9">Command line tools, </text:span><text:span text:style-name="T9"/></text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P56" loext:marker-style-name="T9"><text:span text:style-name="T9">Build Tools, </text:span><text:span text:style-name="T9"/></text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P56" loext:marker-style-name="T9"><text:span text:style-name="T9">Platform Tools, and </text:span><text:span text:style-name="T9"/></text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P56" loext:marker-style-name="T9"><text:span text:style-name="T9">Platform API.</text:span><text:span text:style-name="T9"/></text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="P52" loext:marker-style-name="T9"/>
   <text:p text:style-name="P31" loext:marker-style-name="T9"><text:span text:style-name="T9">If the installation was successful, you will see the version numbers displayed in green.</text:span><text:span text:style-name="T9"/></text:p>
   <text:p text:style-name="P5" loext:marker-style-name="T29"><draw:frame draw:style-name="fr2" draw:name="Picture 62" text:anchor-type="as-char" svg:width="6.2547in" svg:height="4.3209in"><draw:image draw:mime-type="image/png">
