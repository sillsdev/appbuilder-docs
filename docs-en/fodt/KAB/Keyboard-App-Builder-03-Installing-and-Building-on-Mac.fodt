     <text:p text:style-name="Contents_20_2" loext:marker-style-name="T15"><text:a xlink:type="simple" xlink:href="#_Toc228363883" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link">4.3.<text:span text:style-name="T15"><text:tab/></text:span>Install Transporter<text:span text:style-name="T14"><text:tab/>11</text:span></text:a></text:p>
     <text:p text:style-name="Contents_20_1" loext:marker-style-name="T12"><text:a xlink:type="simple" xlink:href="#_Toc228363884" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link"><text:span text:style-name="T13">5.</text:span><text:span text:style-name="T12"><text:tab/></text:span>Building a Keyboard App for iOS<text:span text:style-name="T14"><text:tab/>11</text:span></text:a></text:p>
     <text:p text:style-name="Contents_20_2" loext:marker-style-name="T15"><text:a xlink:type="simple" xlink:href="#_Toc228363885" text:style-name="Index_20_Link" text:visited-style-name="Index_20_Link"><text:span text:style-name="T9">5.1.</text:span><text:span text:style-name="T15"><text:tab/></text:span><text:span text:style-name="T9">Apple Development Store Setup</text:span><text:span text:style-name="T14"><text:tab/>11</text:span></text:a></text:p>
