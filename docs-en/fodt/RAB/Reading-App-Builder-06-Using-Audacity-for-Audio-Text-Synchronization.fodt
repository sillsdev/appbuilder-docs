    <text:list-item>
     <text:p text:style-name="P70" loext:marker-style-name="T4"><text:span text:style-name="T4">You will be asked if you want to make the change. Click </text:span><text:span text:style-name="T16">OK</text:span><text:span text:style-name="T4"> to do this.</text:span></text:p>
    </text:list-item>
   </text:list>
