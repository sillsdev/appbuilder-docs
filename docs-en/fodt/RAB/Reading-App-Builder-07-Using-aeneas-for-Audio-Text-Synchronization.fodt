   <text:p text:style-name="P27" loext:marker-style-name="T4"/>
   <text:list text:continue-numbering="true" text:style-name="WWNum20">
    <text:list-item>
     <text:p text:style-name="P28" loext:marker-style-name="T4"><text:span text:style-name="T4">Follow the instructions in the wizard. You can accept all the defaults. </text:span><text:span text:style-name="T4"/></text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="P26" loext:marker-style-name="T4"/>
   <text:list text:continue-numbering="true" text:style-name="WWNum20">
    <text:list-item>
     <text:p text:style-name="P24" loext:marker-style-name="T4"><text:span text:style-name="T4">On the </text:span><text:span text:style-name="T14">Select Components</text:span><text:span text:style-name="T4"> page, you need the </text:span><text:span text:style-name="T14">Full Installation</text:span><text:span text:style-name="T4"> which should be selected by default.</text:span></text:p>
    </text:list-item>
   </text:list>
