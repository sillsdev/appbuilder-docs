   <text:p text:style-name="P17" loext:marker-style-name="T20"><text:span text:style-name="T19">\ra </text:span><text:span text:style-name="T20">excellent.mp3</text:span><text:span text:style-name="T19"> <text:s text:c="6"/></text:span></text:p>
