    <text:list-item>
     <text:p text:style-name="P43" loext:marker-style-name="T20"><text:span text:style-name="T20">Suivez les instructions de l’assistant. Vous pouvez accepter toutes les valeurs par défaut. </text:span><text:span text:style-name="T20"/></text:p>
    </text:list-item>
   </text:list>
   <text:p text:style-name="P40" loext:marker-style-name="T20"/>
