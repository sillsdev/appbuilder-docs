    <text:list-item>
     <text:p text:style-name="P38" loext:marker-style-name="T20"><text:span text:style-name="T20">Sur la page </text:span><text:span text:style-name="T22">Select Components</text:span><text:span text:style-name="T20"> (Sélectionner les composants), vous avez besoin de </text:span><text:span text:style-name="T22">Full Installation</text:span><text:span text:style-name="T20"> (l’installation complète) qui doit être sélectionnée par défaut.</text:span></text:p>
    </text:list-item>
